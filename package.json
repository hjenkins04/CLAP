{
  "name": "clap-app",
  "version": "0.1.0",
  "description": "Cloud LiDAR Annotation Platform",
  "author": {
    "name": "xonixdevelopment",
    "email": "support@xonixdevelopment.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ libs/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"libs/**/*.{ts,tsx,css}\"",
    "electron:compile": "tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'})+'\\n')\"",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "electron:wait": "wait-on http://localhost:5173 && npm run electron:compile && npm run electron:start",
    "electron:dev": "concurrently -n vite,electron -c blue,green \"vite dev\" \"npm run electron:wait\"",
    "electron:build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false vite build && npm run electron:compile && electron-builder --win",
    "electron:build:publish": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false GH_TOKEN=$GH_TOKEN vite build && npm run electron:compile && electron-builder --win --publish always",
    "electron:preview": "npm run electron:compile && cross-env NODE_ENV=production electron .",
    "icons:generate": "electron-icon-builder --input=build/icon-source.png --output=build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.4",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-hotkeys": "^0.4.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-router": "^1.141.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.561.0",
    "maplibre-gl": "^5.21.1",
    "osmtogeojson": "^3.0.0-beta.5",
    "potree-core": "file:./libs/potree-core",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "~0.154.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "~0.152.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^9.8.0",
    "jsdom": "~22.1.0",
    "prettier": "^2.6.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.xonixdevelopment.clap",
    "productName": "CLAP",
    "copyright": "Copyright © 2025 xonixdevelopment. All rights reserved.",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!dist-electron/**/*.map"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "${productName}",
      "runAfterFinish": true,
      "menuCategory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-${version}-mac.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [{ "target": "AppImage", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "publish": {
      "provider": "generic",
      "url": "https://releases.xonixdevelopment.com/clap/"
    }
  }
}
